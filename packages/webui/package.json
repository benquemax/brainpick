{
  "name": "@brainpick/webui",
  "private": true,
  "version": "0.1.0",
  "description": "brainpick web UI — the live 2D cosmos view of a compiled bundle (PWA)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "node scripts/dev-with-mock.mjs",
    "mock": "node scripts/mock-server.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "npm run build && node ../../scripts/sync-ui.mjs && tsc --noEmit -p e2e/tsconfig.json && playwright test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p e2e/tsconfig.json",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "camera-controls": "^3.0.0",
    "d3-force": "^3.0.0",
    "markdown-it": "^14.3.0",
    "marked": "^15.0.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-gapcursor": "^1.4.1",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.5",
    "prosemirror-model": "^1.25.10",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.42.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.175.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/d3-force": "^3.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.1.0"
  }
}
