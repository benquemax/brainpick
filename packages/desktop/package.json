{
  "name": "@brainpick/desktop",
  "version": "0.1.0",
  "description": "brainpickd — the daemon that owns the magic (git sync, keygen, compile validation, supervision, auth, users, registry) behind a small control API. The Tauri app is a thin client.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "brainpickd": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "brainpick": "^0.1.0",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
