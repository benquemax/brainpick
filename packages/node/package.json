{
  "name": "brainpick",
  "version": "0.1.0",
  "description": "pick your agent's brain — compile and serve OKF knowledge bundles (native Node engine, zero Python)",
  "license": "MIT",
  "homepage": "https://github.com/benquemax/brainpick",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benquemax/brainpick.git",
    "directory": "packages/node"
  },
  "bugs": "https://github.com/benquemax/brainpick/issues",
  "keywords": ["knowledge-graph", "okf", "mcp", "rag", "agents", "brainpick", "llm"],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "brainpick": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "static",
    "skill",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "express": "^5.2.1",
    "smol-toml": "^1.3.1",
    "yaml": "^2.8.0",
    "zod": "^3.25.76"
  },
  "//optionalDependencies": "T2's vector store (spec/30) — absence degrades T2 with an instruction, never breaks T1. apache-arrow is @lancedb/lancedb's peer (schema construction). @huggingface/transformers is the in-process local embedding backend (kind = \"local\") — runs on onnxruntime-node, absence degrades to an instruction same as lancedb.",
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@lancedb/lancedb": "^0.31.0",
    "apache-arrow": "^18.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
